{
  "name": "@qed2/web",
  "version": "0.1.0",
  "description": "QED2 web client (PWA) — browser shell over @qed2/core-logic and @qed2/ui. Static build deploys to GitHub Pages.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/public-sans": "^5.2.7",
    "@qed2/core-logic": "workspace:*",
    "@qed2/ui": "workspace:*",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "fake-indexeddb": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
